{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SkinnyV",
  "version": "0.1.0",
  "identifier": "com.diojeanne.skinnyv",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "control",
        "title": "SkinnyV",
        "width": 480,
        "height": 720,
        "resizable": true,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Lean system audio visualizer",
    "longDescription": "SkinnyV is a lightweight audio visualizer that captures system audio and renders modern visualizations across multiple monitors."
  },
  "plugins": {}
}
