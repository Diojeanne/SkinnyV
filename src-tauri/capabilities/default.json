{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "default",
  "description": "Default capability for SkinnyV",
  "windows": ["control", "visualizer-*"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-set-fullscreen",
    "core:window:allow-start-dragging",
    "core:event:default",
    "shell:allow-open"
  ]
}
